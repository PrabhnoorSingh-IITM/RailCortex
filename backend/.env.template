# ════════════════════════════════════════════════════════════════════════════
# RailCortex Backend Configuration Template
# Copy this file to .env and fill in your actual API keys and settings
# ════════════════════════════════════════════════════════════════════════════

# ─── API Keys & Authentication ────────────────────────────────────────────────

# OpenAI API key for LLM-based dispatch report generation
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mappls API key for routing and maps
# Get from: https://www.mappls.com/
MAPPLS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenWeatherMap API key for live weather data
# Get from: https://openweathermap.org/api
OPENWEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Internal API key for securing endpoints (generate a strong random string)
# Example: openssl rand -hex 32
API_KEY=your-super-secure-random-api-key-here-minimum-16-chars

# Mapbox access token (optional, for frontend maps)
MAPBOX_ACCESS_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─── Database Configuration ───────────────────────────────────────────────────

# SQLite (default, good for development)
DATABASE_URL=sqlite+aiosqlite:///./data/railcortex.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/railcortex

# MongoDB (alternative for document-based storage)
# DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/railcortex


# ─── LLM Configuration ────────────────────────────────────────────────────────

# OpenAI model for dispatch reports
OPENAI_MODEL_FULL=gpt-4o

# OpenAI model for lighter tasks
OPENAI_MODEL_MINI=gpt-4o-mini

# Local Ollama model (for offline dispatch generation)
# Requires Ollama running on http://localhost:11434
OLLAMA_MODEL=llama3.2:latest


# ─── External Service URLs ───────────────────────────────────────────────────

# OpenStreetMap Overpass API for hospital locations
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Mappls routing API endpoint
MAPPLS_ROUTES_URL=https://apis.mappls.com/advancedmaps/v1/route_adv/driving

# OpenWeatherMap API endpoint
OPENWEATHER_API_URL=https://api.openweathermap.org/data/2.5/weather


# ─── Telemetry & Simulation ──────────────────────────────────────────────────

# Interval between telemetry broadcasts (seconds)
TELEMETRY_INTERVAL_SEC=1.0

# Interval between weather data polls (seconds)
WEATHER_POLL_INTERVAL_SEC=300.0

# Hospital search radius configurations (meters)
HOSPITAL_SEARCH_RADII_M=[5000, 15000, 25000, 50000]

# Maximum fallback hospital distance (kilometers)
HOSPITAL_FALLBACK_MAX_KM=150.0


# ─── CORS Configuration ──────────────────────────────────────────────────────

# Frontend URLs allowed to connect (comma-separated)
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000"]


# ─── Logging ──────────────────────────────────────────────────────────────────

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable request/response logging
LOG_REQUESTS=false


# ─── Development & Debugging ─────────────────────────────────────────────────

# Enable debug mode (detailed error messages, hot reload)
DEBUG=false

# Enable CORS for all origins (development only!)
CORS_ALLOW_ALL=false

# Print SQL queries (for debugging)
DATABASE_ECHO=false
