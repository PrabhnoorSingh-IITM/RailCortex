# OpenAI (structured dispatch reports)
OPENAI_API_KEY=

# Map routing (Mappls)
MAPPLS_API_KEY=

# Live weather polling (OpenWeatherMap)
OPENWEATHER_API_KEY=

# API authentication — leave empty to disable auth in local dev
API_KEY=

# Database — defaults to SQLite; use PostgreSQL in production
# DATABASE_URL=sqlite+aiosqlite:///./data/railcortex.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/railcortex

# Ollama fallback model
OLLAMA_MODEL=llama3.2:latest
